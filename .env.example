# ---------- 실서버(Talktail 허브) 연동 ----------
# 배포 예시 전체: monitor/deploy/env.talktail-hub.example 참고

MONITOR_TIMEZONE=Asia/Seoul
MONITOR_SERVER_ID=talktail-hub-01

# nginx 로 노출되는 사이트 베이스 URL (끝에 / 없이)
MONITOR_HUB_SITE_ORIGIN=http://YOUR_PUBLIC_IP_OR_DOMAIN

# 허브 API (로컬 upstream). hub/back .env 의 PORT 와 반드시 일치
MONITOR_HUB_API_ORIGIN=http://127.0.0.1:5001

# 허브와 같은 머신에서 PM2 프로세스 점검
MONITOR_PM2_ENABLED=true

# Vite 빌드 출력 디렉터리 (nginx root 와 동일 권장)
MONITOR_FRONTEND_BUILD_DIR=/home/ubuntu/hub_project/front/dist

# 다중 서버 식별 시 JSON 배열 (선택)
# MONITOR_SERVERS=[{"id":"hub-01"},{"id":"hub-02"}]

# 추가·덮어쓰기 HTTP 검사 (JSON). method+URL 이 같으면 이쪽이 우선
# MONITOR_HTTP_ENDPOINTS=[{"serverId":"talktail-hub-01","url":"https://example.com/api/health","method":"GET","expectedStatus":200,"timeoutMs":8000,"slowThresholdMs":1500}]

MONITOR_LOG_FILES=/home/ubuntu/hub_project/back/logs/error.log

# MONITOR_MQTT_BROKERS, MONITOR_DATABASES, MONITOR_REDIS_INSTANCES, MONITOR_DNS_CHECKS 등은 JSON (선택)

COLLECT_INTERVAL_MS=60000

EMAIL_PROVIDER=smtp
EMAIL_FROM=monitor@yourdomain.com
EMAIL_RECIPIENTS=admin@yourdomain.com,ops@yourdomain.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

STORE_TYPE=sqlite
STORE_PATH=/home/ubuntu/monitor-data/monitor.db
STORE_TTL_DAYS=30
