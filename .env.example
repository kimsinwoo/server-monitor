# 로컬·개발용 스켈레톤. 프로덕션(허브 서버)은 아래 파일을 복사해 사용하세요.
#
#   cp deploy/env.talktail-hub.example .env
#
# 전체 설명·서버 경로·메일 설정은 deploy/env.talktail-hub.example 참고.

MONITOR_TIMEZONE=Asia/Seoul
MONITOR_SERVER_ID=dev-local
MONITOR_HUB_SITE_ORIGIN=
MONITOR_HUB_API_ORIGIN=http://127.0.0.1:5001
COLLECT_INTERVAL_MS=60000
MONITOR_PM2_ENABLED=false
MONITOR_FRONTEND_BUILD_DIR=
MONITOR_LOG_FILES=
EMAIL_PROVIDER=smtp
EMAIL_FROM=
# 여러 명: 쉼표·세미콜론·줄바꿈 구분 (예: a@x.com, b@x.com)
EMAIL_RECIPIENTS=
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
STORE_TYPE=sqlite
STORE_PATH=./data/monitor.db
STORE_TTL_DAYS=30
LOG_LEVEL=debug
