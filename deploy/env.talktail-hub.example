# =============================================================================
# Talktail 허브 서버 — 모니터 프로덕션 환경 변수 예시
# =============================================================================
#
# 배포 후 반드시: git pull → npm ci → npm run build → pm2 restart …
# (구버전 dist 이면 기동 메일에 "스텁", "메시지 큐 수집기" 등 예전 문구가 나옵니다.)
#
# MQTT / DB
#   - 명시: 이 파일에 MQTT_* / DB_* 넣기
#   - 또는 MONITOR_HUB_ENV_PATH=/home/ubuntu/hub_project/back/.env
#   - 또는 생략: MONITOR_FRONTEND_BUILD_DIR=/home/ubuntu/hub_project/front/dist
#     및 MONITOR_LOG_FILES=.../hub_project/back/logs/error.log 처럼 경로만 맞으면
#     back/.env 가 자동 추론되어 병합됩니다(모니터 키가 비어 있을 때만).
#
# 텔레메트리 큐: 허브에 GET /api/monitor/queue-metrics 필요.
#   - back/.env 의 PORT 가 병합되면 기본 http://127.0.0.1:PORT/... (모니터·허브 동일 서버)
#   - 모니터가 다른 머신이면: MONITOR_HUB_QUEUE_USE_LOCALHOST=false + MONITOR_HUB_QUEUE_METRICS_URL=...
#   - 수동: MONITOR_HUB_INTERNAL_API_ORIGIN=http://127.0.0.1:5000
#   - 공인 HTTPS만: nginx /api 프록시 + MONITOR_INTERNAL_TOKEN(허브·모니터 동일)
# =============================================================================

NODE_ENV=production
LOG_LEVEL=info
MONITOR_TIMEZONE=Asia/Seoul
MONITOR_SERVER_ID=talktail-hub-01
COLLECT_INTERVAL_MS=60000

MONITOR_HUB_SITE_ORIGIN=https://creamoff.o-r.kr
# MONITOR_HUB_API_ORIGIN=http://127.0.0.1:5000

# 허브 back/.env 의 PORT(예: 5000)가 병합되면 자동으로 http://127.0.0.1:PORT 로 큐 메트릭 호출(우선순위 높음)
# MONITOR_HUB_INTERNAL_API_ORIGIN=http://127.0.0.1:5000
# MONITOR_HUB_ENV_PATH=/home/ubuntu/hub_project/back/.env

# 큐 정상 시 info 이벤트 주기(ms). 0 이면 비활성. 기본 6시간
# MONITOR_QUEUE_INFO_INTERVAL_MS=21600000

MONITOR_PM2_ENABLED=true
MONITOR_DOCKER_ENABLED=false
MONITOR_FRONTEND_BUILD_DIR=/home/ubuntu/hub_project/front/dist
MONITOR_LOG_FILES=/home/ubuntu/hub_project/back/logs/error.log
MONITOR_SSL_DOMAINS=creamoff.o-r.kr

# MONITOR_INTERNAL_TOKEN=허브_server.js_와_동일
# MONITOR_TELEMETRY_QUEUE_WARNING=500
# MONITOR_TELEMETRY_QUEUE_CRITICAL=5000
# MONITOR_HUB_TELEMETRY_QUEUE=false

EMAIL_PROVIDER=smtp
EMAIL_FROM=monitor@example.com
# 여러 수신자: 쉼표 / 세미콜론 / 줄바꿈 (한 줄 또는 여러 줄)
# EMAIL_RECIPIENTS=ops@example.com,dev@example.com
EMAIL_RECIPIENTS=you@example.com

# 즉시 알림(이벤트 저장 직후 메일): 심각도·detail·스냅샷·규칙 기반 분석 + 전체 JSON 첨부
# MONITOR_INSTANT_ALERTS=false 로 끔 (기본은 켜짐)
# MONITOR_INSTANT_ALERT_MIN_SEVERITY=warning | error | critical | info
# MONITOR_INSTANT_ALERT_COOLDOWN_MS=600000
# MONITOR_INSTANT_ALERT_ATTACH_JSON=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

STORE_TYPE=sqlite
STORE_PATH=/home/ubuntu/monitor-data/monitor.db
STORE_TTL_DAYS=30
