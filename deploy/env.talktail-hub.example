# =============================================================================
# Talktail 허브 서버 — 프로덕션 환경 변수
# =============================================================================
# HTTPS 전용(HTTP 차단) + 공인 도메인(creamoff.o-r.kr) 기준 예시.
#
# 배포
#   sudo mkdir -p /home/ubuntu/monitor-data
#   cd ~/server-monitor   # 또는 레포의 monitor 디렉터리
#   cp deploy/env.talktail-hub.example .env && chmod 600 .env
#   → hub_project/back/.env 의 DB_* / MQTT_* / SMTP_PASS 등을 맞춰 넣기
#   npm ci && npm run build && pm2 restart ecosystem.monitor
#
# HTTP 점검
#   - MONITOR_HUB_SITE_ORIGIN 은 반드시 브라우저에서 쓰는 https:// 도메인
#   - MONITOR_HUB_API_ORIGIN 을 비우면 같은 도메인으로 /api/health 만 검사 (nginx 경유)
#   - 로컬 Node 직접 검사가 필요하면: MONITOR_HUB_API_ORIGIN=http://127.0.0.1:5000
#
# MQTT / MySQL
#   - MONITOR_MQTT_BROKERS / MONITOR_DATABASES JSON 이 비어 있으면
#     hub 와 동일한 MQTT_BROKER_URL·MQTT_USERNAME·MQTT_PASSWORD·DB_* 를 이 파일에 넣으면 자동 점검
# =============================================================================

NODE_ENV=production
LOG_LEVEL=info

# 기동 직후 점검 메일 끄기: MONITOR_STARTUP_EMAIL=false

MONITOR_TIMEZONE=Asia/Seoul
MONITOR_SERVER_ID=talktail-hub-01
COLLECT_INTERVAL_MS=60000

# --- 공인 HTTPS (IP http 로는 막혀 있어도 됨) ---
MONITOR_HUB_SITE_ORIGIN=https://creamoff.o-r.kr
# API 는 nginx 를 탈 때 비워 두면 SITE 와 동일 호스트로 /api/health 검사
# MONITOR_HUB_API_ORIGIN=http://127.0.0.1:5000

# /index.html 직접 URL 이 404 인 경우만 false
# MONITOR_HUB_CHECK_INDEX_HTML=false

MONITOR_PM2_ENABLED=true
MONITOR_DOCKER_ENABLED=false

MONITOR_FRONTEND_BUILD_DIR=/home/ubuntu/hub_project/front/dist
MONITOR_LOG_FILES=/home/ubuntu/hub_project/back/logs/error.log

# SSL 만료 감시 (Let's Encrypt 등)
MONITOR_SSL_DOMAINS=creamoff.o-r.kr

# --- hub_project/back/.env 와 동일하게 복사 (모니터 자동 MQTT·DB 점검용) ---
MQTT_BROKER_URL=mqtt://127.0.0.1:1883
MQTT_USERNAME=
MQTT_PASSWORD=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=hubProjectDB

# JSON 위전 수동 설정 시 위 MQTT_/DB_ 보다 우선 (한 줄)
# MONITOR_MQTT_BROKERS=[{"serverId":"talktail-hub-01","url":"mqtt://127.0.0.1:1883"}]
# MONITOR_DATABASES=[{"serverId":"talktail-hub-01","type":"mysql","host":"127.0.0.1","port":3306,"user":"root","password":"","database":"hubProjectDB"}]

# --- 메일 (SMTP_PASS 는 hub 의 NOTIFY_EMAIL_PASS 와 동일하게 — git 커밋 금지) ---
EMAIL_PROVIDER=smtp
EMAIL_FROM=dev.sinwoo@gmail.com
EMAIL_RECIPIENTS=dev.sinwoo@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dev.sinwoo@gmail.com
SMTP_PASS=

STORE_TYPE=sqlite
STORE_PATH=/home/ubuntu/monitor-data/monitor.db
STORE_TTL_DAYS=30
