# Talktail 허브 실서버(Ubuntu + nginx + PM2) 기준 예시.
# 사용: cp deploy/env.talktail-hub.example monitor/.env 후 값만 수정.

MONITOR_TIMEZONE=Asia/Seoul
MONITOR_SERVER_ID=talktail-hub-01
COLLECT_INTERVAL_MS=60000

# 공인 사이트(nginx 80/443) — deploy/nginx-hub.example.conf 의 server_name 과 맞출 것
MONITOR_HUB_SITE_ORIGIN=http://103.218.159.131

# Node API (upstream). hub/back/server.js 의 PORT·.env 와 동일하게 (예: 5000 또는 5001)
MONITOR_HUB_API_ORIGIN=http://127.0.0.1:5001

# PM2 허브 프로세스(server)와 함께 쓰려면 true
MONITOR_PM2_ENABLED=true

# Vite 빌드 산출물 — nginx root 와 동일 경로 권장
MONITOR_FRONTEND_BUILD_DIR=/home/ubuntu/hub_project/front/dist

# 허브 백엔드 PM2 로그(선택)
MONITOR_LOG_FILES=/home/ubuntu/hub_project/back/logs/error.log

# DB 점검(선택, JSON 배열 — 비밀번호는 .env에만)
# MONITOR_DATABASES=[{"serverId":"talktail-hub-01","type":"mysql","host":"127.0.0.1","port":3306,"user":"app","password":"***","database":"talktail","slowQueryThresholdMs":800}]

# SSL 만료 감시할 도메인(쉼표 구분)
# MONITOR_SSL_DOMAINS=your.domain.example

# 메일
EMAIL_PROVIDER=smtp
EMAIL_FROM=monitor@yourdomain.com
EMAIL_RECIPIENTS=ops@yourdomain.com
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# 이벤트 저장 (디스크 여유 있는 경로)
STORE_TYPE=sqlite
STORE_PATH=/home/ubuntu/monitor-data/monitor.db
STORE_TTL_DAYS=30

# MONITOR_HTTP_ENDPOINTS 로 위 자동 항목을 덮어쓰거나 추가 URL을 정의할 수 있음 (동일 method+url 키는 JSON 쪽이 우선)
