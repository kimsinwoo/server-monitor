{
  "name": "server-daily-digest-monitor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/report/templates && cp src/report/templates/*.html dist/report/templates/",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "mqtt": "^5.10.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "pm2": "^5.4.3",
    "puppeteer": "^24.41.0",
    "systeminformation": "^5.23.5",
    "uuid": "^11.0.3",
    "winston": "^3.17.0"
  },
  "optionalDependencies": {
    "mysql2": "^3.11.5",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/dockerode": "^3.3.31",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
